  "description": "travel tracking app built with react native",
  "author": "brandon",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "branch-clean-up": "git branch -lvv | cut -c3- | awk '/: gone]/ {print $1}' | xargs git branch -D",
