{
  "name": "traveltracker-mobile",
  "version": "3.3.1",
  "description": "travel tracking app built with react native",
  "author": "brandon",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "branch-clean-up": "git branch -lvv | cut -c3- | awk '/: gone]/ {print $1}' | xargs git branch -D",
    "build": "eas build --platform ios",
    "start": "npx expo start",
    "submit": "eas submit -p ios"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blsnwbrdr/traveltracker-mobile.git"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "babel-preset-expo": "~55.0.8",
    "expo": "^55.0.0",
    "expo-asset": "~55.0.17",
    "expo-font": "~55.0.8",
    "expo-splash-screen": "~55.0.21",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "^0.7.4"
  }
}
