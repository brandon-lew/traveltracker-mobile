{
  "name": "traveltracker-mobile",
  "version": "3.3.1",
  "description": "travel tracking app built with react native",
  "author": "brandon",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "branch-clean-up": "git branch -lvv | cut -c3- | awk '/: gone]/ {print $1}' | xargs git branch -D",
    "build": "eas build --platform ios",
    "start": "npx expo start",
    "submit": "eas submit -p ios"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blsnwbrdr/traveltracker-mobile.git"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@rneui/base": "^4.0.0-rc.7",
    "@rneui/themed": "^4.0.0-rc.8",
    "expo": "^53.0.0",
    "expo-asset": "~11.1.7",
    "expo-font": "~13.3.2",
    "expo-splash-screen": "~0.30.10",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  }
}
